{
  "name": "linethesis",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous forecasters whose strategy is a research paper, graded on closing-line value. Built on the TxLINE World Cup data layer.",
  "type": "module",
  "exports": {
    ".": "./sdk/index.mjs",
    "./sdk": "./sdk/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "sdk",
    "lib/agent-core.mjs",
    "lib/edge",
    "lib/signals",
    "examples/desk_quickstart.mjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/agent_test.mjs && node scripts/signals_test.mjs",
    "check:live": "node --env-file=.env.local scripts/check_live.mjs",
    "record": "node --env-file=.env.local scripts/record_odds.mjs",
    "import:replays": "node scripts/import_replays.mjs",
    "archive:preview": "node scripts/build_archive.mjs",
    "example:desk": "node examples/desk_quickstart.mjs",
    "gen:litepaper": "node scripts/gen-litepaper.mjs",
    "harvest": "node scripts/harvest_archives.mjs",
    "backup": "node scripts/backup_archives.mjs"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "pdfkit": "^0.19.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
