{
  "name": "lagisalpha",
  "version": "0.1.4",
  "private": false,
  "description": "Paper-trade the lead-lag edge in prediction markets. A market lags TxLINE's vig-free fair, so the cheap side is underpriced; this CLI streams every divergence and plays it out as a Kelly-sized paper trade at fair. Signal only, no real orders.",
  "type": "module",
  "license": "AGPL-3.0",
  "bin": {
    "lagisalpha": "bin/lagisalpha.mjs"
  },
  "files": [
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cnpierrepapi/lagisalpha.git"
  },
  "homepage": "https://lagisalpha.vercel.app",
  "keywords": [
    "prediction-markets",
    "polymarket",
    "kelly-criterion",
    "trading",
    "paper-trading",
    "cli",
    "txline",
    "arbitrage"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/gen-litepaper.mjs || true",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/guard_no_client_supabase.mjs && node scripts/guard_blob_budget.mjs && node scripts/agent_test.mjs && node scripts/signals_test.mjs && node scripts/paper_test.mjs && node scripts/telegram_test.mjs",
    "check:live": "node --env-file=.env.local scripts/check_live.mjs",
    "record": "node --env-file=.env.local scripts/record_odds.mjs",
    "import:replays": "node scripts/import_replays.mjs",
    "archive:preview": "node scripts/build_archive.mjs",
    "example:desk": "node examples/desk_quickstart.mjs",
    "gen:litepaper": "node scripts/gen-litepaper.mjs",
    "harvest": "node scripts/harvest_archives.mjs",
    "backup": "node scripts/backup_archives.mjs"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "16.2.9",
    "pdfkit": "^0.19.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
